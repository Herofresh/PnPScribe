DATABASE_URL=postgresql://pnp:pnp@localhost:5432/pnp
REDIS_URL=redis://127.0.0.1:6379
OPENAI_API_KEY="sk-your-openai-key"

AI_MODEL_CHEAP=gpt-4o-mini
ENTITY_QUEUE_NAME=entity-extraction-jobs
ENTITY_CONFIDENCE_THRESHOLD=0.5
ENTITY_RULE_LINK_WINDOW=10

# Image extraction is ON by default
ENTITY_IMAGE_EXTRACTION_ENABLED=true
ENTITY_IMAGE_MAX_PAGES=3
ENTITY_IMAGE_TARGET_WIDTH=1400

PNPSCRIBE_ROOT=/path/to/PnPScribe
