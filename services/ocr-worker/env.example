# Environment variables for the OCR worker

DATABASE_URL="postgresql://pnp:pnp@localhost:5432/pnp"
REDIS_URL="redis://127.0.0.1:6379"
OPENAI_API_KEY="sk-your-openai-key"

AI_EMBED_MODEL="text-embedding-3-small"
OCR_TRANSCRIBE_MODEL="gpt-4.1-mini"
OCR_QUEUE_NAME="ocr-document-jobs"
PNPSCRIBE_ROOT="/path/to/PnPScribe"

# Optional: limit pages during development
OCR_DEV_PAGE_CAP=10
