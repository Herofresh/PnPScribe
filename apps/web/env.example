# Environment variables for the web application

# Database connection string for PostgreSQL
DATABASE_URL="postgresql://pnp:pnp@localhost:5432/pnp"

# OpenAI API key for accessing the language models
OPENAI_API_KEY="sk-your-openai-key"

# default / cheap
AI_MODEL_CHEAP="gpt-4o-mini"
# optional reasoning/stronger
AI_MODEL_STRONG="gpt-4.1"
# embeddings
AI_EMBED_MODEL="text-embedding-3-small"

REDIS_URL="redis://127.0.0.1:6379"
