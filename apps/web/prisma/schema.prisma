generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model System {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  documents Document[]
  entities  Entity[]
}

model Document {
  id               String    @id @default(cuid())
  filePath         String
  extractedText    String?
  extractedTextLength Int?
  extractedPageCount  Int?
  extractionDurationMs Int?
  ocrStatus         String    @default("not_requested")
  ocrMode           String?
  ocrReason         String?
  ocrError          String?
  ocrRequestedAt    DateTime?
  ocrCompletedAt    DateTime?
  ocrProgressCurrentPage Int?
  ocrProgressTotalPages  Int?
  ocrProgressMessage     String?
  ocrProgressUpdatedAt   DateTime?
  entityStatus          String    @default("idle")
  entityError           String?
  entityProgressMessage String?
  entityProgressUpdatedAt DateTime?
  entityExtractedCount  Int?
  entityRuleLinkCount   Int?
  entityImageCount      Int?
  entityMetaStatus      String    @default("idle")
  entityMetaError       String?
  entityMetaModel       String?
  entityMetaJson        Json?
  entityMetaUpdatedAt   DateTime?
  extractionStatus String    @default("pending")
  extractionError  String?
  extractedAt      DateTime?
  systemId         String
  system           System    @relation(fields: [systemId], references: [id])
  chunks           Chunk[]
  groups           ChunkGroup[]
  entities         Entity[]
  entityImages     EntityImage[]
  chapters         DocumentChapter[]
  createdAt        DateTime  @default(now())
}

model Chunk {
  id         String    @id @default(cuid())
  content    String
  chunkIndex Int
  pageNumber Int?
  chapterHint String?
  kind       String?
  labels     Json?
  embedding  Unsupported("vector")?
  documentId String
  document   Document  @relation(fields: [documentId], references: [id])
  groupId    String?
  group      ChunkGroup? @relation(fields: [groupId], references: [id])
  ruleLinks  EntityRuleLink[]
  createdAt  DateTime  @default(now())
}

model ChunkGroup {
  id              String   @id @default(cuid())
  documentId      String
  document        Document @relation(fields: [documentId], references: [id])
  kind            String
  groupIndex      Int
  title           String?
  chapterHint     String?
  startChunkIndex Int
  endChunkIndex   Int
  startPage       Int?
  endPage         Int?
  chunks          Chunk[]
  entities        Entity[]
  createdAt       DateTime @default(now())

  @@index([documentId, groupIndex])
}

model Entity {
  id               String   @id @default(cuid())
  systemId         String
  system           System   @relation(fields: [systemId], references: [id])
  documentId       String
  document         Document @relation(fields: [documentId], references: [id])
  groupId          String?
  group            ChunkGroup? @relation(fields: [groupId], references: [id])
  type             String
  name             String
  slug             String
  sourcePageStart  Int?
  sourcePageEnd    Int?
  sourceChunkStart Int
  sourceChunkEnd   Int
  confidence       Float
  extractionMethod String
  coreData         Json
  rawData          Json?
  ruleLinks        EntityRuleLink[]
  images           EntityImage[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([systemId, type, slug, sourceChunkStart, sourceChunkEnd])
  @@index([systemId, type])
  @@index([documentId])
}

model EntityRuleLink {
  id         String @id @default(cuid())
  entityId   String
  entity     Entity @relation(fields: [entityId], references: [id])
  chunkId    String
  chunk      Chunk  @relation(fields: [chunkId], references: [id])
  relation   String
  confidence Float
  rationale  String?
  createdAt  DateTime @default(now())

  @@unique([entityId, chunkId, relation])
  @@index([entityId])
}

model EntityImage {
  id         String   @id @default(cuid())
  entityId   String
  entity     Entity   @relation(fields: [entityId], references: [id])
  documentId String
  document   Document @relation(fields: [documentId], references: [id])
  pageNumber Int
  filePath   String
  kind       String
  createdAt  DateTime @default(now())

  @@index([entityId])
}

model DocumentChapter {
  id          String   @id @default(cuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id])
  title       String
  pageStart   Int?
  pageEnd     Int?
  level       Int?
  createdAt   DateTime @default(now())

  @@index([documentId])
}
