generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model System {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  documents Document[]
}

model Document {
  id               String    @id @default(cuid())
  filePath         String
  extractedText    String?
  extractedTextLength Int?
  extractedPageCount  Int?
  extractionDurationMs Int?
  ocrStatus         String    @default("not_requested")
  ocrMode           String?
  ocrReason         String?
  ocrError          String?
  ocrRequestedAt    DateTime?
  ocrCompletedAt    DateTime?
  ocrProgressCurrentPage Int?
  ocrProgressTotalPages  Int?
  ocrProgressMessage     String?
  ocrProgressUpdatedAt   DateTime?
  extractionStatus String    @default("pending")
  extractionError  String?
  extractedAt      DateTime?
  systemId         String
  system           System    @relation(fields: [systemId], references: [id])
  chunks           Chunk[]
  createdAt        DateTime  @default(now())
}

model Chunk {
  id         String    @id @default(cuid())
  content    String
  chunkIndex Int
  pageNumber Int?
  chapterHint String?
  embedding  Unsupported("vector")?
  documentId String
  document   Document  @relation(fields: [documentId], references: [id])
  createdAt  DateTime  @default(now())
}
